# --- HTTP ---
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
LOG_LEVEL=info

# --- Auth ---
# 32-byte base64 key for HS256 JWTs.
JWT_SECRET=replace-me-with-32-bytes-of-random-base64
JWT_ISSUER=shm
JWT_AUDIENCE=shm-api

# --- Postgres ---
DATABASE_URL=postgres://shm:shm@127.0.0.1:5432/shm

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379

# --- Credential encryption (AES-256-GCM) ---
# 32-byte base64 key, used as the active version.
# For rotation, set KEY_VERSIONS to a JSON object: {"1":"...key1...","2":"...key2..."}
# Latest numeric key is the writer; older keys are readers only.
CRED_ENC_KEY=replace-me-with-32-bytes-of-random-base64

# --- Polling ---
POLL_CONCURRENCY=64
POLL_DEFAULT_INTERVAL_S=60
POLL_JITTER_S=5

# --- Vendor HTTP ---
VENDOR_HTTP_TIMEOUT_MS=4000
VENDOR_HTTP_RETRIES=2
