    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/jwt": "^9.0.1",
    "@fastify/websocket": "^11.0.1",
    "bullmq": "^5.12.0",
